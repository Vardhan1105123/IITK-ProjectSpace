/* Page wrapper */
.app-shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background-color: var(--bg-page);
}

/* Sidebar plus Main contnent wrapper */
.app-body {
  flex: 1;
  display: flex;
  flex-direction: row;
  min-height: 0;
  overflow: hidden;
}

/* Main scrollable area */
.pcf-main {
  flex: 1;
  padding: 28px 32px 48px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  overflow-y: auto;
}

.pcf-faq-hint {
  font-size: 13px;
  color: var(--text-muted);
}

.pcf-form-container {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

/* Card */
.pcf-card {
  background: var(--bg-card);
  border-radius: 16px;
  padding: 24px 28px;
  border: 1px solid var(--border-color);
  box-shadow: 0 2px 12px rgba(10, 65, 116, 0.06);
}

.pcf-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24px;
}

.pcf-section-label {
  font-size: 12.5px;
  color: var(--text-muted);
  font-weight: 500;
  letter-spacing: 0.02em;
  margin-bottom: 4px;
}

.pcf-section-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

/* Dropdown */
.pcf-dropdown-wrapper {
  position: relative;
}

.pcf-dropdown-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 16px;
  border: 1.5px solid var(--border-color);
  border-radius: 10px;
  background: var(--bg-card);
  font-size: 14px;
  font-weight: 500;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  cursor: pointer;
  min-width: 145px;
  justify-content: space-between;
  transition: border-color 0.15s, box-shadow 0.15s;
}

.pcf-dropdown-btn:hover {
  border-color: var(--color-slate);
  box-shadow: 0 1px 4px rgba(0, 29, 57, 0.08);
}

.pcf-chevron {
  transition: transform 0.2s ease;
  flex-shrink: 0;
}

.pcf-chevron--open {
  transform: rotate(180deg);
}

.pcf-dropdown-menu {
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  background: var(--bg-card);
  border: 1.5px solid var(--border-color);
  border-radius: 10px;
  overflow: hidden;
  min-width: 145px;
  box-shadow: 0 4px 16px rgba(0, 29, 57, 0.12);
  z-index: 50;
  animation: pcf-fade-in 0.12s ease;
}

@keyframes pcf-fade-in {
  from { opacity: 0; transform: translateY(-4px); }
  to   { opacity: 1; transform: translateY(0); }
}

.pcf-dropdown-item {
  display: block;
  width: 100%;
  padding: 10px 16px;
  text-align: left;
  background: transparent;
  border: none;
  font-size: 14px;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  cursor: pointer;
  transition: background 0.12s;
}

.pcf-dropdown-item:hover {
  background: var(--bg-card-header);
}

.pcf-dropdown-item--active {
  font-weight: 600;
  color: var(--color-dark);
  background: color-mix(in srgb, var(--color-sky) 12%, transparent);
}

/* Fields */
.pcf-field {
  margin-bottom: 24px;
}

.pcf-field:last-child {
  margin-bottom: 0;
}

.pcf-label {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 5px;
}

.pcf-label-hint {
  display: block;
  font-size: 12.5px;
  font-weight: 400;
  color: var(--text-muted);
  margin-top: 2px;
  margin-bottom: 10px;
}

/* Inputs */
.pcf-input {
  width: 100%;
  padding: 10px 14px;
  border: 1.5px solid var(--border-color);
  border-radius: 8px;
  font-size: 14px;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  background: var(--bg-card-header);
  outline: none;
  transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
}

.pcf-input::placeholder {
  color: var(--text-muted);
}

.pcf-input:focus {
  border-color: var(--color-teal);
  background: var(--bg-card);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-teal) 15%, transparent);
}

.pcf-input--link {
  padding-left: 38px;
}

.pcf-input--search {
  padding-left: 12px;
  border: none;
  outline: none;
  box-shadow: none;
  background: transparent;
}

.pcf-input--search:focus {
  border: none;
  box-shadow: none;
}

/* Split-pane markdown editor */
.pcf-split-pane {
  display: flex;
  gap: 0;
  border: 1.5px solid var(--border-color);
  border-radius: 8px;
  overflow: hidden;
  min-height: 200px;
}

.pcf-split-editor {
  flex: 1;
  border: none !important;
  border-right: 1.5px solid var(--border-color) !important;
  border-radius: 0 !important;
  box-shadow: none !important;
  resize: none;
  min-height: 200px;
}

.pcf-split-editor:focus {
  box-shadow: none !important;
  border-color: var(--border-color) !important;
}

.pcf-split-preview {
  flex: 1;
  padding: 12px 16px;
  font-size: 14px;
  line-height: 1.7;
  color: var(--text-primary);
  background: var(--bg-card);
  overflow-y: auto;
  min-height: 200px;
}

.pcf-split-preview h1,
.pcf-split-preview h2,
.pcf-split-preview h3 {
  font-weight: 700;
  margin: 0.6em 0 0.3em;
  color: var(--text-primary);
}

.pcf-split-preview p { margin: 0.4em 0; }

.pcf-split-preview code {
  background: color-mix(in srgb, var(--color-sky) 15%, transparent);
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 13px;
}

.pcf-split-preview pre {
  background: var(--bg-card-header);
  border: 1px solid var(--border-color);
  border-radius: 6px;
  padding: 12px;
  overflow-x: auto;
  font-size: 13px;
}

.pcf-split-preview ul,
.pcf-split-preview ol {
  padding-left: 1.4em;
