            )}

            {/* Submit */}
            <div className="pcf-submit-row">
              <button className="pcf-submit-btn" onClick={handleSubmit} disabled={isSubmitting}>
                {isSubmitting ? "Publishing..." : `Publish ${postType}`}
              </button>
            </div>

          </div>
        </main>
      </div>
    </div>
  );
}
