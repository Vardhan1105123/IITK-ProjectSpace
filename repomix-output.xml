/* SIDEBAR */
.sidebar {
  position: relative;
  left: 0;
  top: 0;
  bottom: 0;
  z-index: 200;

  width: var(--sidebar-width-collapsed);
  display: flex;
  flex-direction: column;
  padding: 12px 0;

  background-color: var(--color-darkest);
  border-right: 1px solid rgba(123, 189, 232, 0.1);

  transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

.sidebar--expanded {
  width: var(--sidebar-width-expanded);
}

/* Toggle button */
.sidebar__toggle {
  display: flex;
  align-items: center;
  gap: 10px;

  width: calc(100% - 16px);
  margin: 0 8px 12px;
  padding: 8px 10px;

  border-radius: 10px;
  border: none;
  background: transparent;
  color: var(--color-slate);
  cursor: pointer;
  flex-shrink: 0;
  white-space: nowrap;

  transition: background 0.18s, color 0.18s, width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.sidebar__toggle:hover {
  background-color: rgba(123, 189, 232, 0.08);
  color: var(--color-sky);
}

/* When collapsed, center the toggle icon */
.sidebar:not(.sidebar--expanded) .sidebar__toggle {
  width: 44px;
  margin: 0 8px 12px;
  padding: 8px;
}

.sidebar__toggle-label {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  
  opacity: 0;
  transform: translateX(-6px);
  transition: opacity 0.2s ease 0.05s, transform 0.2s ease 0.05s;
  pointer-events: none;
}

/* Nav list */
.sidebar__nav {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
  width: 100%;
  padding: 0 8px;
}

/* Individual nav button */
.sidebar__nav-item {
  position: relative;
  display: flex;
  align-items: center;
  gap: 12px;

  width: 44px;
  height: 44px;
  padding: 0 10px;
  border-radius: 12px;
  border: none;
  background: transparent;
  color: white;
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;

  transition: background 0.18s, color 0.18s, transform 0.15s, width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Expanded: stretch full nav width */
.sidebar--expanded .sidebar__nav-item {
  width: 100%;
}

.sidebar__nav-item:hover {
  background-color: rgba(123, 189, 232, 0.1);
  color: var(--color-sky);
  transform: translateX(2px);
}

.sidebar__nav-item--active {
  background-color: rgba(78, 142, 162, 0.2);
  color: var(--color-sky);
}

/* Active left indicator bar */
.sidebar__nav-item--active::before {
  content: "";
  position: absolute;
  left: -8px;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 24px;
  border-radius: 0 3px 3px 0;
  background-color: var(--color-sky);
}

/* Icon wrapper */
.sidebar__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 0;
  flex-shrink: 0;
}

/* Label (visible only when expanded) */
.sidebar__label {
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.01em;
  color: inherit;

  opacity: 0;
  transform: translateX(-6px);
  transition: opacity 0.2s ease 0.05s, transform 0.2s ease 0.05s;
  pointer-events: none;
}

.sidebar--expanded .sidebar__toggle-label {
  opacity: 0.7;
  transform: translateX(0);
}

.sidebar--expanded .sidebar__label {
  opacity: 1;
  transform: translateX(0);
}

/* Notification badge */
.sidebar__badge {
  position: absolute;
  top: 6px;
  right: 6px;

  min-width: 16px;
  height: 16px;
  padding: 0 4px;

  background-color: var(--color-teal);
  border-radius: 999px;
  border: 2px solid var(--color-darkest);

  font-size: 9px;
  font-weight: 700;
  color: #fff;
  line-height: 12px;
  text-align: center;
}

/* notifications badge will be at the right most end when expanded */
.sidebar--expanded .sidebar__badge {
  top: 50%;
  right: 12px;
  transform: translateY(-50%);
}

/* Bottom section (logout) */
.sidebar__bottom {
  width: 100%;
  padding: 0 8px;
  margin-top: 8px;
}

.sidebar__logout {
  color: rgba(255, 255, 255, 0.6);
}

.sidebar__logout:hover {
  color: #e87b7b;
  background-color: rgba(232, 123, 123, 0.1);
  transform: translateX(2px);
}
