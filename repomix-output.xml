/* Page wrapper */
.app-shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background-color: var(--bg-page);
}

/* Sidebar plus Main contnent wrapper */
.app-body {
  flex: 1;
  display: flex;
  flex-direction: row;
  min-height: 0;
  overflow: hidden;
}

/* Main scrollable area */
.pcf-main {
  flex: 1;
  padding: 28px 32px 48px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  overflow-y: auto;
}

.pcf-faq-hint {
  font-size: 13px;
  color: var(--text-muted);
}

.pcf-form-container {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

/* Card */
.pcf-card {
  background: var(--bg-card);
  border-radius: 16px;
  padding: 24px 28px;
  border: 1px solid var(--border-color);
  box-shadow: 0 2px 12px rgba(10, 65, 116, 0.06);
}

.pcf-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24px;
}

.pcf-section-label {
  font-size: 12.5px;
  color: var(--text-muted);
  font-weight: 500;
  letter-spacing: 0.02em;
  margin-bottom: 4px;
}

.pcf-section-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

/* Dropdown */
.pcf-dropdown-wrapper {
  position: relative;
}

.pcf-dropdown-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 16px;
  border: 1.5px solid var(--border-color);
  border-radius: 10px;
  background: var(--bg-card);
  font-size: 14px;
  font-weight: 500;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  cursor: pointer;
  min-width: 145px;
  justify-content: space-between;
  transition: border-color 0.15s, box-shadow 0.15s;
}

.pcf-dropdown-btn:hover {
  border-color: var(--color-slate);
  box-shadow: 0 1px 4px rgba(0, 29, 57, 0.08);
}

.pcf-chevron {
  transition: transform 0.2s ease;
  flex-shrink: 0;
}

.pcf-chevron--open {
  transform: rotate(180deg);
}

.pcf-dropdown-menu {
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  background: var(--bg-card);
  border: 1.5px solid var(--border-color);
  border-radius: 10px;
  overflow: hidden;
  min-width: 145px;
  box-shadow: 0 4px 16px rgba(0, 29, 57, 0.12);
  z-index: 50;
  animation: pcf-fade-in 0.12s ease;
}

@keyframes pcf-fade-in {
  from { opacity: 0; transform: translateY(-4px); }
  to   { opacity: 1; transform: translateY(0); }
}

.pcf-dropdown-item {
  display: block;
  width: 100%;
  padding: 10px 16px;
  text-align: left;
  background: transparent;
  border: none;
  font-size: 14px;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  cursor: pointer;
  transition: background 0.12s;
}

.pcf-dropdown-item:hover {
  background: var(--bg-card-header);
}

.pcf-dropdown-item--active {
  font-weight: 600;
  color: var(--color-dark);
  background: color-mix(in srgb, var(--color-sky) 12%, transparent);
}

/* Fields */
.pcf-field {
  margin-bottom: 24px;
}

.pcf-field:last-child {
  margin-bottom: 0;
}

.pcf-label {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 5px;
}

.pcf-label-hint {
  display: block;
  font-size: 12.5px;
  font-weight: 400;
  color: var(--text-muted);
  margin-top: 2px;
  margin-bottom: 10px;
}

/* Inputs */
.pcf-input {
  width: 100%;
  padding: 10px 14px;
  border: 1.5px solid var(--border-color);
  border-radius: 8px;
  font-size: 14px;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  background: var(--bg-card-header);
  outline: none;
  transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
}

.pcf-input::placeholder {
  color: var(--text-muted);
}

.pcf-input:focus {
  border-color: var(--color-teal);
  background: var(--bg-card);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-teal) 15%, transparent);
}

.pcf-input--link {
  padding-left: 38px;
}

.pcf-input--search {
  padding-left: 12px;
  border: none;
  outline: none;
  box-shadow: none;
  background: transparent;
}

.pcf-input--search:focus {
  border: none;
  box-shadow: none;
}

/* Split-pane markdown editor */
.pcf-split-pane {
  display: flex;
  gap: 0;
  border: 1.5px solid var(--border-color);
  border-radius: 8px;
  overflow: hidden;
  min-height: 200px;
}

.pcf-split-editor {
  flex: 1;
  border: none !important;
  border-right: 1.5px solid var(--border-color) !important;
  border-radius: 0 !important;
  box-shadow: none !important;
  resize: none;
  min-height: 200px;
}

.pcf-split-editor:focus {
  box-shadow: none !important;
  border-color: var(--border-color) !important;
}

.pcf-split-preview {
  flex: 1;
  padding: 12px 16px;
  font-size: 14px;
  line-height: 1.7;
  color: var(--text-primary);
  background: var(--bg-card);
  overflow-y: auto;
  min-height: 200px;
}

.pcf-split-preview h1,
.pcf-split-preview h2,
.pcf-split-preview h3 {
  font-weight: 700;
  margin: 0.6em 0 0.3em;
  color: var(--text-primary);
}

.pcf-split-preview p { margin: 0.4em 0; }

.pcf-split-preview code {
  background: color-mix(in srgb, var(--color-sky) 15%, transparent);
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 13px;
}

.pcf-split-preview pre {
  background: var(--bg-card-header);
  border: 1px solid var(--border-color);
  border-radius: 6px;
  padding: 12px;
  overflow-x: auto;
  font-size: 13px;
}

.pcf-split-preview ul,
.pcf-split-preview ol {
  padding-left: 1.4em;
  margin: 0.4em 0;
}

.pcf-split-preview blockquote {
  border-left: 3px solid var(--color-teal);
  margin: 0.5em 0;
  padding: 4px 12px;
  color: var(--text-muted);
}

.pcf-preview-placeholder {
  color: var(--text-muted);
  font-style: italic;
  font-size: 13.5px;
}

/* Textarea */
.pcf-textarea {
  width: 100%;
  padding: 12px 14px;
  border: 1.5px solid var(--border-color);
  border-radius: 8px;
  font-size: 14px;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  background: var(--bg-card-header);
  outline: none;
  resize: vertical;
  line-height: 1.6;
  transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
}

.pcf-textarea::placeholder {
  color: var(--text-muted);
}

.pcf-textarea:focus {
  border-color: var(--color-teal);
  background: var(--bg-card);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-teal) 15%, transparent);
}

.pcf-textarea--short { min-height: 90px; }
.pcf-textarea--tall  { min-height: 200px; }

/* Tabs */
.pcf-tabs {
  display: flex;
  border-bottom: 2px solid var(--border-color);
  margin-bottom: -2px;
  position: relative;
  z-index: 1;
}

.pcf-tab {
  padding: 8px 18px;
  font-size: 13.5px;
  font-weight: 500;
  font-family: var(--font-montserrat);
  color: var(--text-muted);
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  margin-bottom: -2px;
  transition: color 0.15s, border-color 0.15s;
}

.pcf-tab:hover {
  color: var(--text-primary);
}

.pcf-tab--active {
  color: var(--color-dark);
  border-bottom-color: var(--color-dark);
  font-weight: 600;
}

.pcf-tabs + .pcf-textarea {
  border-top-left-radius: 0;
  border-top: none;
  margin-top: 0;
}

/* Tags */
.pcf-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 10px;
}

.pcf-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 12px;
  background: color-mix(in srgb, var(--color-sky) 15%, transparent);
  color: var(--color-dark);
  border-radius: 999px;
  font-size: 13px;
  font-weight: 600;
  border: 1px solid color-mix(in srgb, var(--color-sky) 40%, transparent);
}

.pcf-tag-remove {
  background: none;
  border: none;
  color: var(--color-mid);
  cursor: pointer;
  font-size: 16px;
  line-height: 1;
  padding: 0;
  opacity: 0.7;
  transition: opacity 0.12s;
}

.pcf-tag-remove:hover {
  opacity: 1;
}

/* Add Button */
.pcf-add-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 9px 16px;
  border: 1px solid var(--border-color);
  border-radius: 10px;
  background: var(--bg-card);
  font-size: 13.5px;
  font-weight: 600;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
}

.pcf-add-btn:hover {
  background: var(--bg-card-header);
  border-color: var(--color-slate);
  box-shadow: 0 1px 4px rgba(0, 29, 57, 0.06);
}

.pcf-add-icon {
  font-size: 18px;
  font-weight: 400;
  line-height: 1;
  color: var(--color-teal);
}

/* Upload Zone */
.pcf-upload-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 32px 20px;
  border: 1.5px dashed var(--color-slate);
  border-radius: 10px;
  background: var(--bg-card-header);
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s, color 0.15s;
  color: var(--text-secondary);
}

.pcf-upload-zone:hover {
  border-color: var(--color-teal);
  background: color-mix(in srgb, var(--color-sky) 10%, var(--bg-card));
  color: var(--color-dark);
}

.pcf-upload-title {
  font-size: 14.5px;
  font-weight: 600;
  color: inherit;
}

.pcf-upload-hint {
  font-size: 12.5px;
  color: var(--text-muted);
}

.pcf-file-list {
  margin-top: 10px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.pcf-file-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 7px 12px;
  background: color-mix(in srgb, var(--color-sky) 12%, transparent);
  border-radius: 7px;
  font-size: 13px;
  color: var(--text-primary);
}

.pcf-file-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.pcf-file-remove {
  background: none;
  border: none;
  font-size: 18px;
  cursor: pointer;
  color: var(--text-muted);
  padding: 0 0 0 8px;
  transition: color 0.12s;
}

.pcf-file-remove:hover {
  color: #c0392b;
}

/* Links */
.pcf-link-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.pcf-link-input-wrapper {
  position: relative;
  flex: 1;
}

.pcf-link-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
  pointer-events: none;
}

.pcf-link-remove {
  background: none;
  border: 1.5px solid var(--border-color);
  border-radius: 7px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  cursor: pointer;
  color: var(--text-muted);
  transition: border-color 0.12s, color 0.12s;
  flex-shrink: 0;
}

.pcf-link-remove:hover {
  border-color: #c0392b;
  color: #c0392b;
}

/* Search / @ input */
.pcf-search-input-wrapper {
  display: flex;
  align-items: center;
  border: 1.5px solid var(--border-color);
  border-radius: 8px;
  background: var(--bg-card-header);
  padding: 0 14px;
  transition: border-color 0.15s, box-shadow 0.15s;
}

.pcf-search-input-wrapper:focus-within {
  border-color: var(--color-teal);
  background: var(--bg-card);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-teal) 15%, transparent);
}

.pcf-at-icon {
  font-size: 14px;
  color: var(--text-muted);
  font-weight: 600;
  margin-right: 4px;
  flex-shrink: 0;
}

.pcf-search-input-wrapper .pcf-input--search {
  flex: 1;
  padding: 10px 0;
}

/* Submit */
.pcf-submit-row {
  display: flex;
  justify-content: flex-end;
  padding-bottom: 8px;
}

.pcf-submit-btn {
  padding: 12px 32px;
  background: var(--color-dark);
  color: #ffffff;
  border: none;
  border-radius: 10px;
  font-size: 14.5px;
  font-weight: 600;
  font-family: var(--font-montserrat);
  cursor: pointer;
  transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
}

.pcf-submit-btn:hover {
  background: var(--color-darkest);
  box-shadow: 0 4px 14px rgba(0, 29, 57, 0.3);
  transform: translateY(-1px);
}

.pcf-submit-btn:active {
  transform: translateY(0);
}

/* Responsive */
@media (max-width: 768px) {
  .pcf-main {
    padding: 16px 16px 40px;
  }

  .pcf-card {
    padding: 20px 18px;
  }

  .pcf-card-header {
    flex-direction: column;
    gap: 14px;
  }

  .pcf-section-title {
    font-size: 18px;
  }

  .pcf-split-pane {
    flex-direction: column;
  }

  .pcf-split-editor {
    border-right: none !important;
    border-bottom: 1.5px solid var(--border-color) !important;
  }
}

/* Action bar */
.edit-page__actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.edit-page__action-btn {
  flex-shrink: 0;
  height: 36px;
  padding: 0 20px;

  background-color: var(--color-mid);
  border: none;
  border-radius: 5px;

  color: #ffffff;
  font-size: 14px;
  font-weight: 500;
  font-family: inherit;
  letter-spacing: 0.02em;
  white-space: nowrap;
  cursor: pointer;

  transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
}

.edit-page__action-btn:hover:not(:disabled) {
  background-color: var(--color-sky);
  box-shadow: 0 4px 14px rgba(78, 142, 162, 0.45);
  transform: translateY(-1px);
}

.edit-page__action-btn:active:not(:disabled) {
  transform: translateY(0);
  box-shadow: none;
}

.edit-page__action-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.edit-page__action-btn--destructive {
  background-color: #a53d2a;
}

.edit-page__action-btn--destructive:hover:not(:disabled) {
  background-color: #8c3222;
  box-shadow: 0 4px 14px rgba(165, 61, 42, 0.35);
}
</file>

<file path="frontend/src/app/projectPage/projectPage.css">
/* Page wrapper */
.app-shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background-color: var(--bg-page);
}

/* Sidebar plus Main contnent wrapper */
.app-body {
  flex: 1;
  display: flex;
  flex-direction: row;
  min-height: 0;
  overflow: hidden;
}

/* Main content area (right of sidebar) */
.project-main {
  flex: 1;
  overflow-y: auto;
  padding: 32px 36px;
  display: flex;
  justify-content: stretch;
  align-items: flex-start;
}

.project-main::-webkit-scrollbar { width: 6px; }
.project-main::-webkit-scrollbar-thumb {
  background: var(--border-color);
  border-radius: 4px;
}

/* Card */
.project-card {
  width: 100%;
  background: var(--bg-card);
  border-radius: 18px;
  border: 1px solid var(--border-color);
  box-shadow: 0 2px 12px rgba(10, 65, 116, 0.06);
  padding: 32px 44px 40px;
  position: relative;
  animation: cardFadeIn 0.35s ease both;
}

@keyframes cardFadeIn {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Creator Row */
.project-creator-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.project-creator-info {
  display: flex;
  align-items: center;
  gap: 10px;
}

.project-creator-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-sky), var(--color-teal));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  color: white;
  flex-shrink: 0;
  overflow: hidden;
}

.project-creator-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}

.project-creator-name {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

/* Title */
.project-title {
  font-size: clamp(1.4rem, 2.6vw, 1.85rem);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: 8px;
}

/* Summary */
.project-summary {
  font-size: 16px;
  color: var(--text-muted);
  font-weight: 400;
  line-height: 1.6;
  margin-bottom: 16px;
}

/* Domain Tags */
.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 24px;
}

.project-tag {
  padding: 5px 14px;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.02em;
  color: #fff;
}

.project-tag:nth-child(3n+1) { background-color: #2d8a6e; }          /* teal */
.project-tag:nth-child(3n+2) { background-color: var(--color-teal); } /* blue */
.project-tag:nth-child(3n+3) { background-color: #a53d2a; }           /* red  */

/* Section Headings */
.project-section-heading {
  font-size: 17px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 10px;
}

/* Description */
.project-description {
  font-size: 16px;
  line-height: 1.75;
  color: var(--text-secondary);
  margin-bottom: 24px;
  white-space: pre-wrap;
}

.markdown-body {
  font-size: 16px;
  line-height: 1.75;
  color: var(--text-secondary);
  margin-bottom: 28px;
}

.markdown-body h1,
.markdown-body h2,
.markdown-body h3,
.markdown-body h4,
.markdown-body h5,
.markdown-body h6 {
  color: var(--text-primary);
  margin-top: 24px;
  margin-bottom: 12px;
  font-weight: 700;
  line-height: 1.25;
}

.markdown-body h1 { font-size: 1.75em; }
.markdown-body h2 { font-size: 1.5em; }
.markdown-body h3 { font-size: 1.25em; }
.markdown-body h4,
.markdown-body h5,
.markdown-body h6 { font-size: 1em; }

.markdown-body p {
  margin-bottom: 16px;
}

.markdown-body ul,
.markdown-body ol {
  margin-bottom: 16px;
  padding-left: 24px;
}

.markdown-body ul { list-style-type: disc; }
.markdown-body ol { list-style-type: decimal; }
.markdown-body li { margin-bottom: 6px; }

.markdown-body a {
  color: var(--color-teal);
  text-decoration: none;
}
.markdown-body a:hover {
  text-decoration: underline;
}

.markdown-body blockquote {
  border-left: 4px solid var(--border-color);
  padding-left: 16px;
  color: var(--text-muted);
  margin: 0 0 16px 0;
}

.markdown-body pre {
  background: var(--bg-page);
  padding: 12px;
  border-radius: 8px;
  overflow-x: auto;
  margin-bottom: 16px;
}

/* Media Grid */
.project-media-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 14px;
  margin-bottom: 28px;
}

.project-media-item {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  border-radius: 10px;
  background: var(--border-color);
}

.project-media-grid.single-media {
  grid-template-columns: 1fr;
}

.project-media-grid.single-media .project-media-item {
  max-height: 340px;
  width: 100%;
  object-fit: cover;
}

/* Divider */
.project-divider {
  border: none;
  border-top: 1px solid var(--border-color);
  margin: 20px 0;
}

/* Team Members */
.project-team {
  margin-bottom: 8px;
}

.project-team-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 4px;
}

.project-team-chip {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 5px 12px 5px 6px;
  background: var(--color-lightest);
  border-radius: 999px;
  border: 1px solid var(--border-color);
  font-size: 15px;
  font-weight: 500;
  color: var(--text-primary);
}

.project-team-avatar {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: 700;
  color: white;
  flex-shrink: 0;
  overflow: hidden;
}

.project-team-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}

/* Avatar color variants — brand palette */
.project-team-avatar.c1 { background: linear-gradient(135deg, var(--color-dark),  var(--color-darkest)); }
.project-team-avatar.c2 { background: linear-gradient(135deg, var(--color-mid),   var(--color-dark)); }
.project-team-avatar.c3 { background: linear-gradient(135deg, var(--color-teal),  var(--color-mid)); }
.project-team-avatar.c4 { background: linear-gradient(135deg, var(--color-slate), var(--color-teal)); }
.project-team-avatar.c5 { background: linear-gradient(135deg, var(--color-sky),   var(--color-slate)); }

/* Links Section */
.project-links {
  margin-bottom: 20px;
}

.project-links-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.project-link-item {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 15px;
  color: var(--color-teal);
  text-decoration: none;
  font-weight: 500;
  word-break: break-all;
}

.project-link-item:hover {
  color: var(--color-dark);
  text-decoration: underline;
}

/* Meta footer */
.project-meta {
  display: flex;
  gap: 18px;
  margin-top: 20px;
  font-size: 14px;
  color: var(--text-muted);
}

.project-meta-item {
  display: flex;
  align-items: center;
  gap: 5px;
}

/* Responsive */
@media (max-width: 700px) {
  .project-main { padding: 20px 12px; }
  .project-card { padding: 20px 18px 28px; }
}
</file>

<file path="frontend/src/app/recruitmentPage/editRecruitmentPage/editRecruitmentPage.css">
/* Page wrapper */
.app-shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background-color: var(--bg-page);
}

/* Sidebar plus Main contnent wrapper */
.app-body {
  flex: 1;
  display: flex;
  flex-direction: row;
  min-height: 0;
  overflow: hidden;
}

/* Main scrollable area */
.pcf-main {
  flex: 1;
  padding: 28px 32px 48px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  overflow-y: auto;
}

.pcf-faq-hint {
  font-size: 13px;
  color: var(--text-muted);
}

.pcf-form-container {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

/* Card */
.pcf-card {
  background: var(--bg-card);
  border-radius: 16px;
  padding: 24px 28px;
  border: 1px solid var(--border-color);
  box-shadow: 0 2px 12px rgba(10, 65, 116, 0.06);
}

.pcf-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24px;
}

.pcf-section-label {
  font-size: 12.5px;
  color: var(--text-muted);
  font-weight: 500;
  letter-spacing: 0.02em;
  margin-bottom: 4px;
}

.pcf-section-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

/* Dropdown */
.pcf-dropdown-wrapper {
  position: relative;
}

.pcf-dropdown-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 16px;
  border: 1.5px solid var(--border-color);
  border-radius: 10px;
  background: var(--bg-card);
  font-size: 14px;
  font-weight: 500;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  cursor: pointer;
  min-width: 145px;
  justify-content: space-between;
  transition: border-color 0.15s, box-shadow 0.15s;
}

.pcf-dropdown-btn:hover {
  border-color: var(--color-slate);
  box-shadow: 0 1px 4px rgba(0, 29, 57, 0.08);
}

.pcf-chevron {
  transition: transform 0.2s ease;
  flex-shrink: 0;
}

.pcf-chevron--open {
  transform: rotate(180deg);
}

.pcf-dropdown-menu {
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  background: var(--bg-card);
  border: 1.5px solid var(--border-color);
  border-radius: 10px;
  overflow: hidden;
  min-width: 145px;
  box-shadow: 0 4px 16px rgba(0, 29, 57, 0.12);
  z-index: 50;
  animation: pcf-fade-in 0.12s ease;
}

@keyframes pcf-fade-in {
  from { opacity: 0; transform: translateY(-4px); }
  to   { opacity: 1; transform: translateY(0); }
}

.pcf-dropdown-item {
  display: block;
  width: 100%;
  padding: 10px 16px;
  text-align: left;
  background: transparent;
  border: none;
  font-size: 14px;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  cursor: pointer;
  transition: background 0.12s;
}

.pcf-dropdown-item:hover {
  background: var(--bg-card-header);
}

.pcf-dropdown-item--active {
  font-weight: 600;
  color: var(--color-dark);
  background: color-mix(in srgb, var(--color-sky) 12%, transparent);
}

/* Fields */
.pcf-field {
  margin-bottom: 24px;
}

.pcf-field:last-child {
  margin-bottom: 0;
}

.pcf-label {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 5px;
}

.pcf-label-hint {
  display: block;
  font-size: 12.5px;
  font-weight: 400;
  color: var(--text-muted);
  margin-top: 2px;
  margin-bottom: 10px;
}

/* Inputs */
.pcf-input {
  width: 100%;
  padding: 10px 14px;
  border: 1.5px solid var(--border-color);
  border-radius: 8px;
  font-size: 14px;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  background: var(--bg-card-header);
  outline: none;
  transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
}

.pcf-input::placeholder {
  color: var(--text-muted);
}

.pcf-input:focus {
  border-color: var(--color-teal);
  background: var(--bg-card);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-teal) 15%, transparent);
}

.pcf-input--link {
  padding-left: 38px;
}

.pcf-input--search {
  padding-left: 12px;
  border: none;
  outline: none;
  box-shadow: none;
  background: transparent;
}

.pcf-input--search:focus {
  border: none;
  box-shadow: none;
}

/* Split-pane markdown editor */
.pcf-split-pane {
  display: flex;
  gap: 0;
  border: 1.5px solid var(--border-color);
  border-radius: 8px;
  overflow: hidden;
  min-height: 200px;
}

.pcf-split-editor {
  flex: 1;
  border: none !important;
  border-right: 1.5px solid var(--border-color) !important;
  border-radius: 0 !important;
  box-shadow: none !important;
  resize: none;
  min-height: 200px;
}

.pcf-split-editor:focus {
  box-shadow: none !important;
  border-color: var(--border-color) !important;
}

.pcf-split-preview {
  flex: 1;
  padding: 12px 16px;
  font-size: 14px;
  line-height: 1.7;
  color: var(--text-primary);
  background: var(--bg-card);
  overflow-y: auto;
  min-height: 200px;
}

.pcf-split-preview h1,
.pcf-split-preview h2,
.pcf-split-preview h3 {
  font-weight: 700;
  margin: 0.6em 0 0.3em;
  color: var(--text-primary);
}

.pcf-split-preview p { margin: 0.4em 0; }

.pcf-split-preview code {
  background: color-mix(in srgb, var(--color-sky) 15%, transparent);
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 13px;
}

.pcf-split-preview pre {
  background: var(--bg-card-header);
  border: 1px solid var(--border-color);
  border-radius: 6px;
  padding: 12px;
  overflow-x: auto;
  font-size: 13px;
}

.pcf-split-preview ul,
.pcf-split-preview ol {
  padding-left: 1.4em;
  margin: 0.4em 0;
}

.pcf-split-preview blockquote {
  border-left: 3px solid var(--color-teal);
  margin: 0.5em 0;
  padding: 4px 12px;
  color: var(--text-muted);
}

.pcf-preview-placeholder {
  color: var(--text-muted);
  font-style: italic;
  font-size: 13.5px;
}

/* Textarea */
.pcf-textarea {
  width: 100%;
  padding: 12px 14px;
  border: 1.5px solid var(--border-color);
  border-radius: 8px;
  font-size: 14px;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  background: var(--bg-card-header);
  outline: none;
  resize: vertical;
  line-height: 1.6;
  transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
}

.pcf-textarea::placeholder {
  color: var(--text-muted);
}

.pcf-textarea:focus {
  border-color: var(--color-teal);
  background: var(--bg-card);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-teal) 15%, transparent);
}

.pcf-textarea--short { min-height: 90px; }
.pcf-textarea--tall  { min-height: 200px; }

/* Tabs */
.pcf-tabs {
  display: flex;
  border-bottom: 2px solid var(--border-color);
  margin-bottom: -2px;
  position: relative;
  z-index: 1;
}

.pcf-tab {
  padding: 8px 18px;
  font-size: 13.5px;
  font-weight: 500;
  font-family: var(--font-montserrat);
  color: var(--text-muted);
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  margin-bottom: -2px;
  transition: color 0.15s, border-color 0.15s;
}

.pcf-tab:hover {
  color: var(--text-primary);
}

.pcf-tab--active {
  color: var(--color-dark);
  border-bottom-color: var(--color-dark);
  font-weight: 600;
}

.pcf-tabs + .pcf-textarea {
  border-top-left-radius: 0;
  border-top: none;
  margin-top: 0;
}

/* Tags */
.pcf-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 10px;
}

.pcf-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 12px;
  background: color-mix(in srgb, var(--color-sky) 15%, transparent);
  color: var(--color-dark);
  border-radius: 999px;
  font-size: 13px;
  font-weight: 600;
  border: 1px solid color-mix(in srgb, var(--color-sky) 40%, transparent);
}

.pcf-tag-remove {
  background: none;
  border: none;
  color: var(--color-mid);
  cursor: pointer;
  font-size: 16px;
  line-height: 1;
  padding: 0;
  opacity: 0.7;
  transition: opacity 0.12s;
}

.pcf-tag-remove:hover {
  opacity: 1;
}

/* Add Button */
.pcf-add-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 9px 16px;
  border: 1px solid var(--border-color);
  border-radius: 10px;
  background: var(--bg-card);
  font-size: 13.5px;
  font-weight: 600;
  font-family: var(--font-montserrat);
  color: var(--text-primary);
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
}

.pcf-add-btn:hover {
  background: var(--bg-card-header);
  border-color: var(--color-slate);
  box-shadow: 0 1px 4px rgba(0, 29, 57, 0.06);
}

.pcf-add-icon {
  font-size: 18px;
  font-weight: 400;
  line-height: 1;
  color: var(--color-teal);
}

/* Upload Zone */
.pcf-upload-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 32px 20px;
  border: 1.5px dashed var(--color-slate);
  border-radius: 10px;
  background: var(--bg-card-header);
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s, color 0.15s;
  color: var(--text-secondary);
}

.pcf-upload-zone:hover {
  border-color: var(--color-teal);
  background: color-mix(in srgb, var(--color-sky) 10%, var(--bg-card));
  color: var(--color-dark);
}

.pcf-upload-title {
  font-size: 14.5px;
  font-weight: 600;
  color: inherit;
}

.pcf-upload-hint {
  font-size: 12.5px;
  color: var(--text-muted);
}

.pcf-file-list {
  margin-top: 10px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.pcf-file-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 7px 12px;
  background: color-mix(in srgb, var(--color-sky) 12%, transparent);
  border-radius: 7px;
  font-size: 13px;
  color: var(--text-primary);
}

.pcf-file-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.pcf-file-remove {
  background: none;
  border: none;
  font-size: 18px;
  cursor: pointer;
  color: var(--text-muted);
  padding: 0 0 0 8px;
  transition: color 0.12s;
}

.pcf-file-remove:hover {
  color: #c0392b;
}

/* Links */
.pcf-link-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.pcf-link-input-wrapper {
  position: relative;
  flex: 1;
}

.pcf-link-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
  pointer-events: none;
}

.pcf-link-remove {
  background: none;
  border: 1.5px solid var(--border-color);
  border-radius: 7px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  cursor: pointer;
  color: var(--text-muted);
  transition: border-color 0.12s, color 0.12s;
  flex-shrink: 0;
}

.pcf-link-remove:hover {
  border-color: #c0392b;
  color: #c0392b;
}

/* Search / @ input */
.pcf-search-input-wrapper {
  display: flex;
  align-items: center;
  border: 1.5px solid var(--border-color);
  border-radius: 8px;
  background: var(--bg-card-header);
  padding: 0 14px;
  transition: border-color 0.15s, box-shadow 0.15s;
}

.pcf-search-input-wrapper:focus-within {
  border-color: var(--color-teal);
  background: var(--bg-card);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-teal) 15%, transparent);
}

.pcf-at-icon {
  font-size: 14px;
  color: var(--text-muted);
  font-weight: 600;
  margin-right: 4px;
  flex-shrink: 0;
}

.pcf-search-input-wrapper .pcf-input--search {
  flex: 1;
  padding: 10px 0;
}

/* Submit */
.pcf-submit-row {
  display: flex;
  justify-content: flex-end;
  padding-bottom: 8px;
}

.pcf-submit-btn {
  padding: 12px 32px;
  background: var(--color-dark);
  color: #ffffff;
  border: none;
  border-radius: 10px;
  font-size: 14.5px;
  font-weight: 600;
  font-family: var(--font-montserrat);
  cursor: pointer;
  transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
}

.pcf-submit-btn:hover {
  background: var(--color-darkest);
  box-shadow: 0 4px 14px rgba(0, 29, 57, 0.3);
  transform: translateY(-1px);
}

.pcf-submit-btn:active {
  transform: translateY(0);
}

/* Responsive */
@media (max-width: 768px) {
  .pcf-main {
    padding: 16px 16px 40px;
  }

  .pcf-card {
    padding: 20px 18px;
  }

  .pcf-card-header {
    flex-direction: column;
    gap: 14px;
  }

  .pcf-section-title {
    font-size: 18px;
  }

  .pcf-split-pane {
    flex-direction: column;
  }

  .pcf-split-editor {
    border-right: none !important;
    border-bottom: 1.5px solid var(--border-color) !important;
  }
}

/* Action bar */
.edit-page__actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.edit-page__action-btn {
  flex-shrink: 0;
  height: 36px;
  padding: 0 20px;

  background-color: var(--color-mid);
  border: none;
  border-radius: 5px;

  color: #ffffff;
  font-size: 14px;
  font-weight: 500;
  font-family: inherit;
  letter-spacing: 0.02em;
  white-space: nowrap;
  cursor: pointer;

  transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
}

.edit-page__action-btn:hover:not(:disabled) {
  background-color: var(--color-sky);
  box-shadow: 0 4px 14px rgba(78, 142, 162, 0.45);
  transform: translateY(-1px);
}

.edit-page__action-btn:active:not(:disabled) {
  transform: translateY(0);
  box-shadow: none;
}

.edit-page__action-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.edit-page__action-btn--destructive {
  background-color: #a53d2a;
}

.edit-page__action-btn--destructive:hover:not(:disabled) {
  background-color: #8c3222;
  box-shadow: 0 4px 14px rgba(165, 61, 42, 0.35);
}
