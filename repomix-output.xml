  border-color: #c0392b;
  color: #c0392b;
}

/* Search / @ input */
.pcf-search-input-wrapper {
  display: flex;
  align-items: center;
  border: 1.5px solid var(--border-color);
  border-radius: 8px;
  background: var(--bg-card-header);
  padding: 0 14px;
  transition: border-color 0.15s, box-shadow 0.15s;
}

.pcf-search-input-wrapper:focus-within {
  border-color: var(--color-teal);
  background: var(--bg-card);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-teal) 15%, transparent);
}

.pcf-at-icon {
  font-size: 14px;
  color: var(--text-muted);
  font-weight: 600;
  margin-right: 4px;
  flex-shrink: 0;
}

.pcf-search-input-wrapper .pcf-input--search {
  flex: 1;
  padding: 10px 0;
}

/* Submit */
.pcf-submit-row {
  display: flex;
  justify-content: flex-end;
  padding-bottom: 8px;
}

.pcf-submit-btn {
  padding: 12px 32px;
  background: var(--color-dark);
