<file path="frontend/src/app/recruitmentPage/recruitmentPage.css">
/* Page wrapper */
.app-shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background-color: var(--bg-page);
}

/* Sidebar plus Main contnent wrapper */
.app-body {
  flex: 1;
  display: flex;
  flex-direction: row;
  min-height: 0;
  overflow: hidden;
}

/* Main content area */
.recruit-main {
  flex: 1;
  overflow-y: auto;
  padding: 32px 36px;
  display: flex;
  justify-content: stretch;
  align-items: flex-start;
}

.recruit-main::-webkit-scrollbar { width: 6px; }
.recruit-main::-webkit-scrollbar-thumb {
  background: var(--border-color);
  border-radius: 4px;
}

/* Card */
.recruit-card {
  width: 100%;
  background: var(--bg-card);
  border-radius: 18px;
  border: 1px solid var(--border-color);
  box-shadow: 0 2px 12px rgba(10, 65, 116, 0.06);
  padding: 32px 44px 40px;
  position: relative;
  animation: cardFadeIn 0.35s ease both;
}

@keyframes cardFadeIn {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Top Row: recruiters inline + Apply button */
.recruit-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.recruit-recruiters-inline {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

/* Stacked avatars for the top row */
.recruit-avatar-stack {
  display: flex;
  align-items: center;
}

.recruit-avatar-stack-item {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 2px solid var(--bg-card);
  margin-left: -8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 700;
  color: white;
  overflow: hidden;
  flex-shrink: 0;
}

.recruit-avatar-stack-item:first-child { margin-left: 0; }
.recruit-avatar-stack-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}

.recruit-avatar-stack-item.c1 { background: linear-gradient(135deg, var(--color-dark), var(--color-darkest)); }
.recruit-avatar-stack-item.c2 { background: linear-gradient(135deg, var(--color-mid), var(--color-dark)); }
.recruit-avatar-stack-item.c3 { background: linear-gradient(135deg, var(--color-teal), var(--color-mid)); }
.recruit-avatar-stack-item.c4 { background: linear-gradient(135deg, var(--color-slate), var(--color-teal)); }
.recruit-avatar-stack-item.c5 { background: linear-gradient(135deg, var(--color-sky), var(--color-slate)); }

.recruit-recruiters-label {
  font-size: 15px;
  font-weight: 500;
  color: var(--text-secondary);
}

/* Status Badge */
.recruit-status-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 4px 12px;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.03em;
}

.recruit-status-badge.open {
  background-color: rgba(46, 204, 158, 0.12);
  color: #1a9e72;
  border: 1px solid rgba(46, 204, 158, 0.3);
}

.recruit-status-badge.closed {
  background-color: rgba(165, 61, 42, 0.10);
  color: #a53d2a;
  border: 1px solid rgba(165, 61, 42, 0.25);
}

.recruit-status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.recruit-status-badge.open   .recruit-status-dot { background-color: #1a9e72; }
.recruit-status-badge.closed .recruit-status-dot { background-color: #a53d2a; }

/* Apply Button */
.recruit-apply-btn {
  padding: 9px 26px;
  background: var(--color-dark);
  color: white;
  border: none;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  box-shadow: 0 2px 8px rgba(0, 29, 57, 0.25);
  transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
}

.recruit-apply-btn:hover {
  background: var(--color-darkest);
  transform: translateY(-1px);
  box-shadow: 0 5px 14px rgba(0, 29, 57, 0.3);
}

.recruit-apply-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

/* Title */
.recruit-title {
  font-size: clamp(1.4rem, 2.6vw, 1.85rem);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: 16px;
}

/* Domain Tags */
.recruit-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 24px;
}

.recruit-tag {
  padding: 5px 14px;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.02em;
  color: #fff;
}

.recruit-tag:nth-child(3n+1) { background-color: #2d8a6e; }   /* teal  */
.recruit-tag:nth-child(3n+2) { background-color: var(--color-teal); }  /* blue  */
.recruit-tag:nth-child(3n+3) { background-color: #a53d2a; }   /* red   */

/* Section Heading */
.recruit-section-heading {
  font-size: 17px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 10px;
}

/* Description */
.recruit-description {
  font-size: 16px;
  line-height: 1.75;
  color: var(--text-secondary);
  margin-bottom: 24px;
  white-space: pre-wrap;
}

.markdown-body {
  font-size: 16px;
  line-height: 1.75;
  color: var(--text-secondary);
  margin-bottom: 28px;
}

.markdown-body h1,
.markdown-body h2,
.markdown-body h3,
.markdown-body h4,
.markdown-body h5,
.markdown-body h6 {
  color: var(--text-primary);
  margin-top: 24px;
  margin-bottom: 12px;
  font-weight: 700;
  line-height: 1.25;
}

.markdown-body h1 { font-size: 1.75em; }
.markdown-body h2 { font-size: 1.5em; }
.markdown-body h3 { font-size: 1.25em; }
.markdown-body h4,
.markdown-body h5,
.markdown-body h6 { font-size: 1em; }

.markdown-body p {
  margin-bottom: 16px;
}

.markdown-body ul,
.markdown-body ol {
  margin-bottom: 16px;
  padding-left: 24px;
}

.markdown-body ul { list-style-type: disc; }
.markdown-body ol { list-style-type: decimal; }
.markdown-body li { margin-bottom: 6px; }

.markdown-body a {
  color: var(--color-teal);
  text-decoration: none;
}
.markdown-body a:hover {
  text-decoration: underline;
}

.markdown-body blockquote {
  border-left: 4px solid var(--border-color);
  padding-left: 16px;
  color: var(--text-muted);
  margin: 0 0 16px 0;
}

.markdown-body pre {
  background: var(--bg-page);
  padding: 12px;
  border-radius: 8px;
  overflow-x: auto;
  margin-bottom: 16px;
}

/* Divider */
.recruit-divider {
  border: none;
  border-top: 1px solid var(--border-color);
  margin: 20px 0;
}

/* Prerequisites */
.recruit-prereq-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.recruit-prereq-tag {
  padding: 5px 14px;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 600;
  color: #fff;
}

.recruit-prereq-tag:nth-child(3n+1) { background-color: #2d8a6e; }
.recruit-prereq-tag:nth-child(3n+2) { background-color: var(--color-teal); }
.recruit-prereq-tag:nth-child(3n+3) { background-color: #a53d2a; }

/* Eligibility */
.recruit-eligibility-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 8px;
}

@media (max-width: 600px) {
  .recruit-eligibility-grid { grid-template-columns: 1fr; }
}

.recruit-eligibility-group-label {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 8px;
}

.recruit-eligibility-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
}

.recruit-eligibility-chip {
  padding: 4px 12px;
  background: var(--bg-page);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-secondary);
}

/* Recruiters */
.recruit-recruiter-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.recruit-recruiter-chip {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 5px 12px 5px 6px;
  background: var(--color-lightest);
  border-radius: 999px;
  border: 1px solid var(--border-color);
  font-size: 15px;
  font-weight: 500;
  color: var(--text-primary);
}

.recruit-recruiter-avatar {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: 700;
  color: white;
